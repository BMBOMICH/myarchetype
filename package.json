{
  "name": "myarchetype",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:web": "expo export --platform web",
    "export": "expo export --platform web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky",
    "audit:types": "tsc --noEmit --pretty",
    "audit:lint": "eslint . --max-warnings=0",
    "audit:format": "prettier --check .",
    "audit:deps": "depcheck --json > depcheck.json && npm audit --omit=dev --json > npm-audit.json",
    "audit:local": "npm run typecheck && npm run audit:lint && npm run audit:format && npm run audit:deps && npm test -- --passWithNoTests",
    "audit:web-perf": "npx lighthouse http://localhost:8081 --output=json --output-path=lighthouse.json --chrome-flags='--headless --no-sandbox'",
    "audit:rn-perf": "npx react-native-performance snapshot --output=perf.json",
    "audit:clean": "node -e \"const fs=require('fs');['depcheck.json','npm-audit.json','eslint-report.json','depcheck-report.json','npm-audit-report.json','lighthouse.json','perf.json'].forEach(f=>{try{fs.unlinkSync(f)}catch(e){}})\"",
    "fix": "eslint . --fix && prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "node --localstorage-file=.node/storage.json node_modules/jest/bin/jest.js",
    "test:watch": "node --localstorage-file=.node/storage.json node_modules/jest/bin/jest.js --watch",
    "test:ast": "node --localstorage-file=.node/storage.json node_modules/jest/bin/jest.js __tests__/audit-core-ast.test.ts",
    "test:scroll": "node --localstorage-file=.node/storage.json node_modules/jest/bin/jest.js __tests__/audit-core-scroll.test.ts",
    "test:utils": "node --localstorage-file=.node/storage.json node_modules/jest/bin/jest.js __tests__/audit-core-utils.test.ts"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.5",
    "@expo/vector-icons": "^15.1.1",
    "@legendapp/list": "2.0.19",
    "@legendapp/state": "2.1.15",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "5.99.0",
    "expo": "~55.0.19",
    "expo-asset": "55.0.16",
    "expo-audio": "55.0.14",
    "expo-auth-session": "55.0.15",
    "expo-build-properties": "55.0.13",
    "expo-camera": "^55.0.15",
    "expo-clipboard": "55.0.13",
    "expo-constants": "55.0.15",
    "expo-crypto": "55.0.14",
    "expo-device": "55.0.15",
    "expo-file-system": "^55.0.16",
    "expo-font": "55.0.6",
    "expo-haptics": "55.0.14",
    "expo-image-picker": "55.0.19",
    "expo-linear-gradient": "55.0.13",
    "expo-linking": "55.0.14",
    "expo-location": "^55.1.8",
    "expo-notifications": "55.0.22",
    "expo-router": "~55.0.13",
    "expo-screen-capture": "55.0.13",
    "expo-secure-store": "55.0.13",
    "expo-splash-screen": "55.0.19",
    "expo-status-bar": "55.0.5",
    "expo-symbols": "55.0.7",
    "expo-system-ui": "55.0.16",
    "expo-video": "55.0.15",
    "expo-web-browser": "55.0.14",
    "firebase": "^12.12.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "^1.20.7",
    "react-native-mmkv": "4.3.1",
    "react-native-nitro-haptics": "^0.2.3",
    "react-native-nitro-image": "^0.14.0",
    "react-native-nitro-modules": "0.35.4",
    "react-native-permissions": "^5.5.1",
    "react-native-quick-crypto": "^1.1.0",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-ssl-public-key-pinning": "^1.2.6",
    "react-native-svg": "^15.15.3",
    "react-native-turbo-image": "^1.24.1",
    "react-native-unistyles": "3.2.3",
    "react-native-vision-camera": "^5.0.7",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.7.4",
    "rn-swap": "^0.0.11",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/parser": "7.29.2",
    "@babel/traverse": "7.29.0",
    "@babel/types": "7.29.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint-react/eslint-plugin": "^5.6.2",
    "@eslint/js": "10.0.1",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "babel-plugin-transform-remove-console": "6.9.4",
    "depcheck": "1.4.7",
    "eslint": "10.2.1",
    "eslint-config-expo": "55.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "55.0.16",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "react-native-bundle-visualizer": "4.0.0",
    "react-test-renderer": "19.2.0",
    "recast": "0.23.11",
    "ts-jest": "29.4.9",
    "tsx": "4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.58.2"
  },
  "pnpm": {
    "strictPeerDependencies": false,
    "supportedArchitectures": {
      "os": [
        "win32"
      ],
      "cpu": [
        "x64"
      ]
    },
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@sentry/cli",
      "esbuild",
      "protobufjs",
      "unrs-resolver"
    ],
    "overrides": {
      "zod": "4.3.6",
      "hermes-parser": "0.35.0",
      "debug": "4.4.3",
      "type-fest": "4.33.0",
      "glob": "^10.4.5",
      "rimraf": "^5.0.10",
      "@xmldom/xmldom": "^0.9.8"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ]
      }
    }
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "sideEffects": false
}