{
  "name": "myarchetype",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "export": "expo export --platform web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "jest",
    "save": "git add . && git commit -m \"Update\" && git push",
    "prepare": "husky",
    "audit:fast": "node project-scanner.js",
    "audit:types": "tsc --noEmit --pretty",
    "audit:lint": "eslint . --max-warnings=0",
    "audit:format": "prettier --check .",
    "audit:deps": "depcheck --json > depcheck.json && npm audit --omit=dev --json > npm-audit.json",
    "audit:local": "npm run audit:fast && npm run audit:types && npm run audit:lint && npm run audit:format && npm run audit:deps && npx jest --passWithNoTests",
    "audit:report": "npm run audit:fast && npm run audit:types && npm run audit:lint --format json --output-file eslint-report.json && npx depcheck --json > depcheck-report.json && npm audit --json > npm-audit-report.json && npx jest --coverage --passWithNoTests",
    "audit:web-perf": "npx lighthouse http://localhost:8081 --output=json --output-path=lighthouse.json --chrome-flags='--headless --no-sandbox'",
    "audit:rn-perf": "npx react-native-performance snapshot --output=perf.json",
    "audit:clean": "rm -f depcheck.json npm-audit.json eslint-report.json depcheck-report.json npm-audit-report.json lighthouse.json perf.json || true"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "^2.3.1",
    "axios": "^1.14.0",
    "expo": "~55.0.11",
    "expo-asset": "~55.0.12",
    "expo-audio": "~55.0.11",
    "expo-auth-session": "~55.0.12",
    "expo-av": "^16.0.8",
    "expo-camera": "~55.0.13",
    "expo-clipboard": "~55.0.11",
    "expo-constants": "~55.0.11",
    "expo-crypto": "~55.0.12",
    "expo-device": "~55.0.12",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.11",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.16",
    "expo-linear-gradient": "~55.0.11",
    "expo-linking": "~55.0.11",
    "expo-location": "~55.1.6",
    "expo-notifications": "~55.0.16",
    "expo-router": "~55.0.10",
    "expo-screen-capture": "^55.0.11",
    "expo-secure-store": "~55.0.11",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.13",
    "expo-video": "~55.0.13",
    "expo-web-browser": "~55.0.12",
    "firebase": "^12.11.0",
    "nsfwjs": "^4.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.3.0",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.2",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^25.5.2",
    "@types/react": "~19.2.14",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "depcheck": "^1.4.7",
    "eslint": "^9.15.0",
    "eslint-config-expo": "~55.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.13",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react-native-bundle-visualizer": "^4.0.0",
    "react-native-performance": "^5.1.0",
    "react-test-renderer": "19.2.4",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "glob": "^10.3.0",
    "rimraf": "^5.0.0",
    "inflight": false,
    "abab": false,
    "domexception": false,
    "whatwg-encoding": "^3.1.1"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "build": "expo export",
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom",
        "react-test-renderer",
        "jest",
        "typescript",
        "react-native-gesture-handler",
        "react-native-reanimated",
        "react-native-safe-area-context",
        "react-native-screens",
        "react-native-worklets"
      ]
    }
  }
}
