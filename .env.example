# .env.example — ADD THESE REQUIRED VARIABLES

# Legal compliance
ID_OBFUSCATION_SECRET=           # 32+ byte random secret for API ID obfuscation
AUDIT_LOG_SIGNING_KEY=           # HMAC key for tamper-evident audit logs
LITIGATION_HOLD_ENCRYPTION_KEY=  # For encrypting litigation hold data

# Child safety (REQUIRED — federal law)
NCMEC_ESP_API_KEY=               # From NCMEC Electronic Service Provider portal
NCMEC_ESP_ORG_ID=                # Your organization's NCMEC ID
PHOTODNA_API_KEY=                # From Microsoft via NCMEC
GIFCT_API_KEY=                   # Global Internet Forum to Counter Terrorism

# AI safety
LLAMA_GUARD_ENDPOINT=            # Self-hosted or HF Inference endpoint
DUOGUARD_ENDPOINT=               # Content moderation endpoint
MODEL_PERFORMANCE_WEBHOOK=       # Alert endpoint for model drift

# Infrastructure security
WAF_ENABLED=true                 # Web Application Firewall
RATE_LIMIT_STORE=redis://        # Redis for distributed rate limiting
THREAT_INTEL_KEY=                # AbuseIPDB or similar

# Health data (HIPAA-adjacent)
HEALTH_DATA_ENCRYPTION_KEY=      # AES-256 key for health data at rest
HEALTH_DATA_REGION=              # Must match data residency requirements

# Server config
FIREBASE_PROJECT_ID=
NODE_ENV=
PORT=

# Child Safety / NCMEC
EXPO_PUBLIC_NCMEC_ENDPOINT=
EXPO_PUBLIC_NCMEC_API_KEY=
EXPO_PUBLIC_HASH_DB_URL=

# HaveIBeenPwned
EXPO_PUBLIC_HIBP_API_KEY=

