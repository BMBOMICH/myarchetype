rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════

    // ── Authentication ────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.admin == true;
    }

    function isBanned() {
      return isAuthenticated() &&
        request.auth.token.banned == true;
    }

    function isNotBanned() {
      return isAuthenticated() && !isBanned();
    }

    function isEmailVerified() {
      return isAuthenticated() &&
        request.auth.token.email_verified == true;
    }

    function isVerifiedUser() {
      return isNotBanned() && isEmailVerified();
    }

    // ── Validation ────────────────────────────
    function isValidString(field, minLen, maxLen) {
      return field is string &&
        field.size() >= minLen &&
        field.size() <= maxLen;
    }

    function isValidNumber(field, min, max) {
      return field is number &&
        field >= min &&
        field <= max;
    }

    function isValidList(field, minLen, maxLen) {
      return field is list &&
        field.size() >= minLen &&
        field.size() <= maxLen;
    }

    function isValidTimestamp(field) {
      return field == request.time;
    }

    // ── Field guards ──────────────────────────
    function fieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(fields);
    }

    function onlyChangedFields(fields) {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ── User-specific guards ──────────────────
    // Fields that only the server / admin can modify
    function isProtectedUserUpdate() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny([
          'isAdmin', 'isBanned', 'bannedAt', 'bannedBy',
          'createdAt', 'uid', 'email',
          // Server-computed fields — users must NOT be able to inflate these
          'ratings', 'matchCount', 'profileViews', 'referralCount',
          'achievements', 'achievementPoints', 'trustScore'
        ]);
    }

    // ═══════════════════════════════════════════
    // USERS
    // ═══════════════════════════════════════════
    match /users/{userId} {

      // Any authenticated user can read profiles for matching/discovery.
      // Sensitive fields (email, location coords) should be excluded
      // at the query level in your app code, or use a /publicProfiles
      // subcollection in the future.
      allow read: if isAuthenticated();

      // Profile creation — must match ALL fields your app actually sends
      // from profile-setup.tsx doSave()
      allow create: if isOwner(userId) && isVerifiedUser() &&
        hasRequiredFields([
          'uid', 'email', 'name', 'age', 'gender',
          'interestedIn', 'photos', 'profileComplete', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          // Identity
          'uid', 'email', 'name', 'age', 'birthday',
          'zodiacSign', 'zodiacEmoji',

          // Demographics
          'gender', 'interestedIn', 'pronouns',
          'height', 'bodyType', 'lookingFor',

          // Lifestyle & values
          'religiousViews', 'lifestyle', 'relationshipGoal',
          'education', 'occupation', 'smoking', 'drinking',
          'children', 'pets', 'diet', 'politicalViews',

          // Interests & personality
          'interests', 'loveLanguage', 'communicationStyle',
          'preferredFirstDate', 'vibes',

          // Preferences (nested object)
          'preferences',

          // Bio & prompts
          'bio', 'promptAnswers',

          // Photos
          'photos', 'photoData', 'hasFullBodyPhoto',

          // Privacy (nested object)
          'privacy',

          // Location
          'location', 'locationCity',

          // Verification
          'ageVerification',

          // System fields set on create
          'createdAt', 'updatedAt', 'profileComplete',
          'photoVerified', 'selfieVerified', 'isVisible',
          'termsAcceptedAt',

          // Defaults (initialised to zero/null/empty)
          'ratings', 'personalityType', 'icebreakers',
          'achievements', 'achievementPoints',
          'loginStreak', 'lastLoginDate',
          'matchCount', 'profileViews', 'referralCount',

          // Admin (set by server, but present at create with defaults)
          'isAdmin', 'isBanned'
        ]) &&
        request.resource.data.uid == userId &&
        request.resource.data.email == request.auth.token.email &&
        isValidTimestamp(request.resource.data.createdAt) &&
        isValidString(request.resource.data.name, 1, 30) &&
        isValidNumber(request.resource.data.age, 18, 99) &&
        isValidList(request.resource.data.photos, 1, 6) &&
        request.resource.data.profileComplete == true;

      // Owner can update their own profile, but NOT protected fields
      allow update: if isAdmin() ||
        (isOwner(userId) && isVerifiedUser() &&
         !isProtectedUserUpdate() &&
         fieldsUnchanged(['createdAt', 'uid', 'email', 'termsAcceptedAt']));

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // LIKES
    // ═══════════════════════════════════════════
    match /likes/{likeId} {
      allow read: if isAuthenticated() &&
        (resource.data.fromUserId == request.auth.uid ||
         resource.data.toUserId == request.auth.uid);

      allow create: if isVerifiedUser() &&
        hasRequiredFields(['fromUserId', 'toUserId', 'createdAt']) &&
        hasOnlyAllowedFields([
          'fromUserId', 'toUserId', 'createdAt', 'type', 'message'
        ]) &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId != request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt) &&
        isValidString(request.resource.data.toUserId, 1, 128);

      allow update: if false;

      allow delete: if isAuthenticated() &&
        resource.data.fromUserId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // CHATS
    // ═══════════════════════════════════════════
    match /chats/{chatId} {
      function isChatParticipant() {
        return request.auth.uid in resource.data.participants;
      }

      function isChatParticipantCreate() {
        return request.auth.uid in request.resource.data.participants;
      }

      allow read: if isAuthenticated() && isChatParticipant();

      allow create: if isVerifiedUser() &&
        isChatParticipantCreate() &&
        hasRequiredFields(['participants', 'createdAt']) &&
        hasOnlyAllowedFields([
          'participants', 'createdAt',
          'lastMessage', 'lastMessageAt', 'lastMessageSenderId'
        ]) &&
        request.resource.data.participants.size() == 2 &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if isVerifiedUser() &&
        isChatParticipant() &&
        fieldsUnchanged(['participants', 'createdAt']);

      allow delete: if false;

      // ── Messages ────────────────────────────
      match /messages/{messageId} {
        function isParentChatParticipant() {
          return request.auth.uid in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }

        allow read: if isAuthenticated() && isParentChatParticipant();

        allow create: if isVerifiedUser() &&
          isParentChatParticipant() &&
          hasRequiredFields(['senderId', 'text', 'createdAt']) &&
          hasOnlyAllowedFields([
            'senderId', 'text', 'createdAt',
            'type', 'mediaUrl', 'readBy', 'edited'
          ]) &&
          request.resource.data.senderId == request.auth.uid &&
          isValidTimestamp(request.resource.data.createdAt) &&
          isValidString(request.resource.data.text, 1, 5000);

        // Allow marking as read or editing own message
        allow update: if isAuthenticated() &&
          isParentChatParticipant() &&
          fieldsUnchanged(['senderId', 'createdAt']);

        // Only sender can delete their own message
        allow delete: if isAuthenticated() &&
          resource.data.senderId == request.auth.uid;
      }

      // ── Typing indicators ───────────────────
      match /typing/{typingId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow write: if isAuthenticated() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          isOwner(typingId);
      }
    }

    // ═══════════════════════════════════════════
    // REPORTS
    // ═══════════════════════════════════════════
    match /reports/{reportId} {
      allow read: if isAdmin() ||
        (isAuthenticated() &&
         resource.data.reporterId == request.auth.uid);

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'reporterId', 'reportedUserId', 'reason', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'reporterId', 'reportedUserId', 'reason',
          'description', 'createdAt', 'status', 'evidence'
        ]) &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reportedUserId != request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt) &&
        isValidString(request.resource.data.reason, 1, 200);

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // RATINGS
    // ═══════════════════════════════════════════
    match /ratings/{ratingId} {
      allow read: if isAdmin() ||
        (isAuthenticated() &&
         (resource.data.raterId == request.auth.uid ||
          resource.data.ratedUserId == request.auth.uid));

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'raterId', 'ratedUserId', 'rating', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'raterId', 'ratedUserId', 'rating', 'createdAt',
          'feedback', 'category'
        ]) &&
        request.resource.data.raterId == request.auth.uid &&
        request.resource.data.ratedUserId != request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt) &&
        isValidNumber(request.resource.data.rating, 1, 5);

      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // RATING STATUS
    // ═══════════════════════════════════════════
    match /ratingStatus/{statusId} {
      // Only the owner can read their own rating status
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isVerifiedUser() &&
        hasRequiredFields(['userId', 'createdAt']) &&
        hasOnlyAllowedFields([
          'userId', 'createdAt', 'status', 'lastRatedAt'
        ]) &&
        request.resource.data.userId == request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if isVerifiedUser() &&
        resource.data.userId == request.auth.uid &&
        fieldsUnchanged(['userId', 'createdAt']);

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // BLOCKED USERS
    // ═══════════════════════════════════════════
    match /blockedUsers/{blockId} {
      allow read: if isAuthenticated() &&
        (resource.data.blockerId == request.auth.uid ||
         resource.data.blockedUserId == request.auth.uid);

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'blockerId', 'blockedUserId', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'blockerId', 'blockedUserId', 'createdAt', 'reason'
        ]) &&
        request.resource.data.blockerId == request.auth.uid &&
        request.resource.data.blockedUserId != request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if false;

      allow delete: if isAuthenticated() &&
        resource.data.blockerId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // RATE LIMITS (server-side only)
    // ═══════════════════════════════════════════
    match /rateLimits/{limitId} {
      allow read: if isOwner(limitId);
      allow write: if false;
    }

    // ═══════════════════════════════════════════
    // BUG REPORTS
    // ═══════════════════════════════════════════
    match /bugReports/{reportId} {
      allow read: if isAdmin() ||
        (isAuthenticated() &&
         resource.data.reporterId == request.auth.uid);

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'reporterId', 'title', 'description', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'reporterId', 'title', 'description', 'createdAt',
          'severity', 'screenshot', 'deviceInfo', 'appVersion',
          'status', 'steps'
        ]) &&
        request.resource.data.reporterId == request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt) &&
        isValidString(request.resource.data.title, 1, 200) &&
        isValidString(request.resource.data.description, 1, 2000);

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // PROFILE VIEWS
    // ═══════════════════════════════════════════
    match /profileViews/{viewId} {
      allow read: if isAuthenticated() &&
        (resource.data.viewerId == request.auth.uid ||
         resource.data.viewedUserId == request.auth.uid);

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'viewerId', 'viewedUserId', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'viewerId', 'viewedUserId', 'createdAt'
        ]) &&
        request.resource.data.viewerId == request.auth.uid &&
        request.resource.data.viewedUserId != request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════
    // REFERRALS
    // ═══════════════════════════════════════════
    match /referrals/{referralId} {
      allow read: if isAuthenticated() &&
        (resource.data.referrerId == request.auth.uid ||
         resource.data.referredUserId == request.auth.uid);

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'referrerId', 'referredUserId', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'referrerId', 'referredUserId', 'createdAt',
          'status', 'rewardClaimed'
        ]) &&
        request.resource.data.referrerId == request.auth.uid &&
        request.resource.data.referredUserId != request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if false;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // ADMIN STATS (server-only)
    // ═══════════════════════════════════════════
    match /adminStats/{statId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ═══════════════════════════════════════════
    // DAILY QUESTIONS
    // ═══════════════════════════════════════════
    match /dailyQuestions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /dailyAnswers/{answerId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'userId', 'questionId', 'answer', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'userId', 'questionId', 'answer', 'createdAt',
          'questionDate'
        ]) &&
        request.resource.data.userId == request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt) &&
        isValidString(request.resource.data.answer, 1, 1000);

      // Allow editing answer but not changing ownership
      allow update: if isVerifiedUser() &&
        resource.data.userId == request.auth.uid &&
        fieldsUnchanged(['userId', 'questionId', 'createdAt']);

      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // PRESENCE
    // ═══════════════════════════════════════════
    match /presence/{userId} {
      allow read: if isAuthenticated();

      allow create, update: if isOwner(userId) &&
        hasOnlyAllowedFields([
          'online', 'lastSeen', 'platform'
        ]) &&
        request.resource.data.lastSeen == request.time;

      allow delete: if isOwner(userId);
    }

    // ═══════════════════════════════════════════
    // STREAKS
    // ═══════════════════════════════════════════
    match /streaks/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId) && isNotBanned() &&
        hasRequiredFields([
          'currentStreak', 'lastLoginDate', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'currentStreak', 'lastLoginDate', 'createdAt',
          'longestStreak'
        ]) &&
        isValidTimestamp(request.resource.data.createdAt) &&
        isValidNumber(request.resource.data.currentStreak, 0, 9999);

      allow update: if isOwner(userId) && isNotBanned() &&
        fieldsUnchanged(['createdAt']) &&
        isValidNumber(request.resource.data.currentStreak, 0, 9999);

      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // NOTIFICATIONS (server creates, user reads)
    // ═══════════════════════════════════════════
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      // Only server/Cloud Functions create notifications
      allow create: if false;

      // Users can only mark as read — nothing else
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        onlyChangedFields(['read', 'readAt']) &&
        request.resource.data.read is bool;

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // PUSH TOKENS
    // ═══════════════════════════════════════════
    match /pushTokens/{userId} {
      allow read: if isAdmin() || isOwner(userId);

      allow create, update: if isOwner(userId) &&
        hasRequiredFields(['token', 'updatedAt']) &&
        hasOnlyAllowedFields([
          'token', 'updatedAt', 'platform', 'deviceId'
        ]) &&
        request.resource.data.updatedAt == request.time &&
        isValidString(request.resource.data.token, 10, 500);

      allow delete: if isOwner(userId);
    }

    // ═══════════════════════════════════════════
    // MATCHES
    // ═══════════════════════════════════════════
    match /matches/{matchId} {
      function isMatchParticipant() {
        return resource.data.user1 == request.auth.uid ||
               resource.data.user2 == request.auth.uid;
      }

      allow read: if isAuthenticated() && isMatchParticipant();

      allow create: if isVerifiedUser() &&
        hasRequiredFields(['user1', 'user2', 'createdAt']) &&
        hasOnlyAllowedFields([
          'user1', 'user2', 'createdAt', 'status', 'matchedAt'
        ]) &&
        (request.resource.data.user1 == request.auth.uid ||
         request.resource.data.user2 == request.auth.uid) &&
        request.resource.data.user1 != request.resource.data.user2 &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if isVerifiedUser() &&
        isMatchParticipant() &&
        fieldsUnchanged(['user1', 'user2', 'createdAt']);

      // Either participant can unmatch
      allow delete: if isAuthenticated() && isMatchParticipant();
    }

    // ═══════════════════════════════════════════
    // SECOND LOOK
    // ═══════════════════════════════════════════
    match /secondLook/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.fromUserId == request.auth.uid;

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'fromUserId', 'toUserId', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'fromUserId', 'toUserId', 'createdAt'
        ]) &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId != request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if false;

      allow delete: if isAuthenticated() &&
        resource.data.fromUserId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // STORIES
    // ═══════════════════════════════════════════
    match /stories/{storyId} {
      // All authenticated users can discover stories
      allow read: if isAuthenticated();

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'userId', 'mediaUrl', 'createdAt', 'expiresAt'
        ]) &&
        hasOnlyAllowedFields([
          'userId', 'mediaUrl', 'createdAt', 'expiresAt',
          'caption', 'type', 'viewCount'
        ]) &&
        request.resource.data.userId == request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt) &&
        // Ensure viewCount starts at 0
        (!('viewCount' in request.resource.data) ||
          request.resource.data.viewCount == 0);

      // Owner can update caption but not change media or ownership
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        fieldsUnchanged([
          'userId', 'createdAt', 'mediaUrl', 'expiresAt'
        ]);

      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ═══════════════════════════════════════════
    // DATE SPOTS
    // ═══════════════════════════════════════════
    match /dateSpots/{spotId} {
      allow read: if isAuthenticated();

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'name', 'location', 'createdBy', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'name', 'location', 'createdBy', 'createdAt',
          'description', 'category', 'rating', 'photos',
          'address', 'reviewCount'
        ]) &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt) &&
        isValidString(request.resource.data.name, 1, 100);

      allow update: if isVerifiedUser() &&
        (resource.data.createdBy == request.auth.uid || isAdmin()) &&
        fieldsUnchanged(['createdBy', 'createdAt']);

      allow delete: if isAdmin() ||
        (isAuthenticated() &&
         resource.data.createdBy == request.auth.uid);
    }

    // ═══════════════════════════════════════════
    // DATE CHECKINS
    // ═══════════════════════════════════════════
    match /dateCheckins/{checkinId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isVerifiedUser() &&
        hasRequiredFields(['userId', 'spotId', 'createdAt']) &&
        hasOnlyAllowedFields([
          'userId', 'spotId', 'createdAt',
          'partnerId', 'rating', 'notes', 'status'
        ]) &&
        request.resource.data.userId == request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        fieldsUnchanged(['userId', 'spotId', 'createdAt']);

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // RELATIONSHIPS
    // ═══════════════════════════════════════════
    match /relationships/{relId} {
      function isRelParticipant() {
        return resource.data.user1 == request.auth.uid ||
               resource.data.user2 == request.auth.uid;
      }

      allow read: if isAuthenticated() && isRelParticipant();

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'user1', 'user2', 'status', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'user1', 'user2', 'status', 'createdAt',
          'updatedAt', 'startedAt'
        ]) &&
        (request.resource.data.user1 == request.auth.uid ||
         request.resource.data.user2 == request.auth.uid) &&
        request.resource.data.user1 != request.resource.data.user2 &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if isVerifiedUser() &&
        isRelParticipant() &&
        fieldsUnchanged(['user1', 'user2', 'createdAt']);

      allow delete: if isAuthenticated() && isRelParticipant();
    }

    // ═══════════════════════════════════════════
    // PERSONALITY RESULTS
    // ═══════════════════════════════════════════
    match /personalityResults/{userId} {
      // Owner and admin can read. Matches can see personality
      // type via the user document instead.
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId) && isNotBanned() &&
        hasRequiredFields(['personalityType', 'createdAt']) &&
        hasOnlyAllowedFields([
          'personalityType', 'createdAt', 'scores', 'answers',
          'updatedAt'
        ]) &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if isOwner(userId) && isNotBanned() &&
        fieldsUnchanged(['createdAt']);

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // DATING STATS
    // ═══════════════════════════════════════════
    match /datingStats/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId) && isNotBanned() &&
        hasRequiredFields(['createdAt']) &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if isOwner(userId) && isNotBanned() &&
        fieldsUnchanged(['createdAt']);

      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // SUPER LIKES
    // ═══════════════════════════════════════════
    match /superLikes/{likeId} {
      allow read: if isAuthenticated() &&
        (resource.data.fromUserId == request.auth.uid ||
         resource.data.toUserId == request.auth.uid);

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'fromUserId', 'toUserId', 'createdAt'
        ]) &&
        hasOnlyAllowedFields([
          'fromUserId', 'toUserId', 'createdAt', 'message'
        ]) &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId != request.auth.uid &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if false;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // SHARED PLAYLISTS
    // ═══════════════════════════════════════════
    match /sharedPlaylists/{playlistId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'participants', 'createdAt', 'name'
        ]) &&
        hasOnlyAllowedFields([
          'participants', 'createdAt', 'name',
          'songs', 'updatedAt'
        ]) &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2 &&
        isValidTimestamp(request.resource.data.createdAt);

      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants &&
        fieldsUnchanged(['participants', 'createdAt']);

      allow delete: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
    }

    // ═══════════════════════════════════════════
    // ICEBREAKERS
    // ═══════════════════════════════════════════
    match /icebreakers/{icebreakerDocId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // ACHIEVEMENTS (definitions — server only)
    // ═══════════════════════════════════════════
    match /achievementDefinitions/{achievementId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ═══════════════════════════════════════════
    // USER SETTINGS / PREFERENCES
    // ═══════════════════════════════════════════
    match /userSettings/{userId} {
      allow read: if isOwner(userId);

      allow create, update: if isOwner(userId) && isNotBanned() &&
        hasOnlyAllowedFields([
          'notifications', 'privacy', 'language',
          'theme', 'updatedAt'
        ]);

      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // COMPATIBILITY RESULTS
    // ═══════════════════════════════════════════
    match /compatibilityResults/{resultId} {
      allow read: if isAuthenticated() &&
        (resource.data.user1 == request.auth.uid ||
         resource.data.user2 == request.auth.uid);

      allow create: if isVerifiedUser() &&
        hasRequiredFields([
          'user1', 'user2', 'score', 'createdAt'
        ]) &&
        (request.resource.data.user1 == request.auth.uid ||
         request.resource.data.user2 == request.auth.uid) &&
        isValidTimestamp(request.resource.data.createdAt) &&
        isValidNumber(request.resource.data.score, 0, 100);

      allow update: if false;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // CATCH-ALL (deny everything not listed)
    // ═══════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}