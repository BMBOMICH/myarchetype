rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.admin == true;
    }

    function isBanned() {
      return isAuthenticated() &&
        request.auth.token.banned == true;
    }

    function isNotBanned() {
      return isAuthenticated() && !isBanned();
    }

    function isValidString(field, minLen, maxLen) {
      return field is string &&
        field.size() >= minLen &&
        field.size() <= maxLen;
    }

    function isValidNumber(field, min, max) {
      return field is number &&
        field >= min &&
        field <= max;
    }

    function fieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(fields);
    }

    function isProtectedUserUpdate() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(['isAdmin', 'isBanned', 'bannedAt', 'bannedBy',
                 'createdAt', 'uid', 'email']);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ═══════════════════════════════════════════
    // USERS
    // ═══════════════════════════════════════════
    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        isOwner(userId) &&
        hasRequiredFields(['displayName', 'email', 'createdAt']) &&
        hasOnlyAllowedFields([
          'displayName', 'email', 'createdAt', 'photoURL',
          'bio', 'gender', 'birthDate', 'location',
          'interests', 'profileComplete', 'personalityType',
          'lastActive', 'uid'
        ]) &&
        request.resource.data.uid == userId &&
        request.resource.data.createdAt == request.time &&
        isValidString(request.resource.data.displayName, 1, 50) &&
        isValidString(request.resource.data.email, 5, 100);

      allow update: if isAdmin() ||
        (isOwner(userId) && isNotBanned() &&
         !isProtectedUserUpdate() &&
         fieldsUnchanged(['createdAt', 'uid', 'email']));

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // LIKES
    // ═══════════════════════════════════════════
    match /likes/{likeId} {
      allow read: if isAuthenticated() &&
        (resource.data.fromUserId == request.auth.uid ||
         resource.data.toUserId == request.auth.uid);

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['fromUserId', 'toUserId', 'createdAt']) &&
        hasOnlyAllowedFields(['fromUserId', 'toUserId', 'createdAt', 'type', 'message']) &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId != request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        isValidString(request.resource.data.toUserId, 1, 128);

      allow update: if false;

      allow delete: if isAuthenticated() &&
        resource.data.fromUserId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // CHATS
    // ═══════════════════════════════════════════
    match /chats/{chatId} {
      function isChatParticipant() {
        return request.auth.uid in resource.data.participants;
      }

      function isChatParticipantCreate() {
        return request.auth.uid in request.resource.data.participants;
      }

      allow read: if isAuthenticated() && isChatParticipant();

      allow create: if isAuthenticated() && isNotBanned() &&
        isChatParticipantCreate() &&
        hasRequiredFields(['participants', 'createdAt']) &&
        hasOnlyAllowedFields(['participants', 'createdAt', 'lastMessage', 'lastMessageAt', 'lastMessageSenderId']) &&
        request.resource.data.participants.size() == 2 &&
        request.resource.data.createdAt == request.time;

      allow update: if isAuthenticated() && isNotBanned() &&
        isChatParticipant() &&
        fieldsUnchanged(['participants', 'createdAt']);

      allow delete: if false;

      // Messages
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if isAuthenticated() && isNotBanned() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          hasRequiredFields(['senderId', 'text', 'createdAt']) &&
          hasOnlyAllowedFields(['senderId', 'text', 'createdAt', 'type', 'mediaUrl', 'readBy', 'edited']) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.createdAt == request.time &&
          isValidString(request.resource.data.text, 1, 5000);

        allow update: if isAuthenticated() && isNotBanned() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          fieldsUnchanged(['senderId', 'createdAt']);

        allow delete: if isAuthenticated() &&
          resource.data.senderId == request.auth.uid;
      }

      // Typing indicators
      match /typing/{typingId} {
        allow read, write: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ═══════════════════════════════════════════
    // REPORTS
    // ═══════════════════════════════════════════
    match /reports/{reportId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.reporterId == request.auth.uid);

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['reporterId', 'reportedUserId', 'reason', 'createdAt']) &&
        hasOnlyAllowedFields(['reporterId', 'reportedUserId', 'reason', 'description', 'createdAt', 'status', 'evidence']) &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reportedUserId != request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        isValidString(request.resource.data.reason, 1, 200);

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // RATINGS
    // ═══════════════════════════════════════════
    match /ratings/{ratingId} {
      allow read: if isAdmin() ||
        (isAuthenticated() &&
         (resource.data.raterId == request.auth.uid ||
          resource.data.ratedUserId == request.auth.uid));

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['raterId', 'ratedUserId', 'rating', 'createdAt']) &&
        hasOnlyAllowedFields(['raterId', 'ratedUserId', 'rating', 'createdAt', 'feedback']) &&
        request.resource.data.raterId == request.auth.uid &&
        request.resource.data.ratedUserId != request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        isValidNumber(request.resource.data.rating, 1, 5);

      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // RATING STATUS
    // ═══════════════════════════════════════════
    match /ratingStatus/{statusId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['userId', 'createdAt']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.createdAt == request.time;

      allow update: if isAuthenticated() && isNotBanned() &&
        resource.data.userId == request.auth.uid &&
        fieldsUnchanged(['userId', 'createdAt']);

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // BLOCKED USERS
    // ═══════════════════════════════════════════
    match /blockedUsers/{blockId} {
      allow read: if isAuthenticated() &&
        (resource.data.blockerId == request.auth.uid ||
         resource.data.blockedUserId == request.auth.uid);

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['blockerId', 'blockedUserId', 'createdAt']) &&
        hasOnlyAllowedFields(['blockerId', 'blockedUserId', 'createdAt', 'reason']) &&
        request.resource.data.blockerId == request.auth.uid &&
        request.resource.data.blockedUserId != request.auth.uid &&
        request.resource.data.createdAt == request.time;

      allow update: if false;

      allow delete: if isAuthenticated() &&
        resource.data.blockerId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // RATE LIMITS (server-side only)
    // ═══════════════════════════════════════════
    match /rateLimits/{limitId} {
      allow read: if isAuthenticated() && isOwner(limitId);
      allow write: if false;
    }

    // ═══════════════════════════════════════════
    // BUG REPORTS
    // ═══════════════════════════════════════════
    match /bugReports/{reportId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.reporterId == request.auth.uid);

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['reporterId', 'title', 'description', 'createdAt']) &&
        hasOnlyAllowedFields(['reporterId', 'title', 'description', 'createdAt', 'severity', 'screenshot', 'deviceInfo', 'appVersion', 'status']) &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        isValidString(request.resource.data.title, 1, 200) &&
        isValidString(request.resource.data.description, 1, 2000);

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // PROFILE VIEWS
    // ═══════════════════════════════════════════
    match /profileViews/{viewId} {
      allow read: if isAuthenticated() &&
        (resource.data.viewerId == request.auth.uid ||
         resource.data.viewedUserId == request.auth.uid);

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['viewerId', 'viewedUserId', 'createdAt']) &&
        hasOnlyAllowedFields(['viewerId', 'viewedUserId', 'createdAt']) &&
        request.resource.data.viewerId == request.auth.uid &&
        request.resource.data.viewedUserId != request.auth.uid &&
        request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════
    // REFERRALS
    // ═══════════════════════════════════════════
    match /referrals/{referralId} {
      allow read: if isAuthenticated() &&
        (resource.data.referrerId == request.auth.uid ||
         resource.data.referredUserId == request.auth.uid);

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['referrerId', 'referredUserId', 'createdAt']) &&
        hasOnlyAllowedFields(['referrerId', 'referredUserId', 'createdAt', 'status', 'rewardClaimed']) &&
        request.resource.data.referrerId == request.auth.uid &&
        request.resource.data.referredUserId != request.auth.uid &&
        request.resource.data.createdAt == request.time;

      allow update: if false;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // ADMIN STATS
    // ═══════════════════════════════════════════
    match /adminStats/{statId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ═══════════════════════════════════════════
    // DAILY QUESTIONS
    // ═══════════════════════════════════════════
    match /dailyQuestions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /dailyAnswers/{answerId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['userId', 'questionId', 'answer', 'createdAt']) &&
        hasOnlyAllowedFields(['userId', 'questionId', 'answer', 'createdAt']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        isValidString(request.resource.data.answer, 1, 1000);

      allow update: if isAuthenticated() && isNotBanned() &&
        resource.data.userId == request.auth.uid &&
        fieldsUnchanged(['userId', 'questionId', 'createdAt']);

      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // PRESENCE
    // ═══════════════════════════════════════════
    match /presence/{userId} {
      allow read: if isAuthenticated();

      allow create, update: if isAuthenticated() &&
        isOwner(userId) &&
        hasOnlyAllowedFields(['online', 'lastSeen', 'platform']) &&
        request.resource.data.lastSeen == request.time;

      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // ═══════════════════════════════════════════
    // STREAKS
    // ═══════════════════════════════════════════
    match /streaks/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);

      allow create: if isAuthenticated() && isOwner(userId) && isNotBanned() &&
        hasRequiredFields(['currentStreak', 'lastLoginDate', 'createdAt']) &&
        hasOnlyAllowedFields(['currentStreak', 'lastLoginDate', 'createdAt', 'longestStreak']) &&
        request.resource.data.createdAt == request.time;

      allow update: if isAuthenticated() && isOwner(userId) && isNotBanned() &&
        fieldsUnchanged(['createdAt']);

      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // NOTIFICATIONS
    // ═══════════════════════════════════════════
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if false;

      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']) &&
        request.resource.data.read is bool;

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // PUSH TOKENS
    // ═══════════════════════════════════════════
    match /pushTokens/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && isOwner(userId));

      allow create, update: if isAuthenticated() && isOwner(userId) &&
        hasRequiredFields(['token', 'updatedAt']) &&
        hasOnlyAllowedFields(['token', 'updatedAt', 'platform', 'deviceId']) &&
        request.resource.data.updatedAt == request.time;

      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // ═══════════════════════════════════════════
    // MATCHES
    // ═══════════════════════════════════════════
    match /matches/{matchId} {
      allow read: if isAuthenticated() &&
        (resource.data.user1 == request.auth.uid ||
         resource.data.user2 == request.auth.uid);

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['user1', 'user2', 'createdAt']) &&
        hasOnlyAllowedFields(['user1', 'user2', 'createdAt', 'status', 'matchedAt']) &&
        (request.resource.data.user1 == request.auth.uid ||
         request.resource.data.user2 == request.auth.uid) &&
        request.resource.data.user1 != request.resource.data.user2 &&
        request.resource.data.createdAt == request.time;

      allow update: if isAuthenticated() && isNotBanned() &&
        (resource.data.user1 == request.auth.uid ||
         resource.data.user2 == request.auth.uid) &&
        fieldsUnchanged(['user1', 'user2', 'createdAt']);

      allow delete: if isAuthenticated() &&
        (resource.data.user1 == request.auth.uid ||
         resource.data.user2 == request.auth.uid);
    }

    // ═══════════════════════════════════════════
    // SECOND LOOK
    // ═══════════════════════════════════════════
    match /secondLook/{docId} {
      allow read: if isAuthenticated() &&
        (resource.data.fromUserId == request.auth.uid ||
         resource.data.toUserId == request.auth.uid);

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['fromUserId', 'toUserId', 'createdAt']) &&
        hasOnlyAllowedFields(['fromUserId', 'toUserId', 'createdAt']) &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId != request.auth.uid &&
        request.resource.data.createdAt == request.time;

      allow update: if false;

      allow delete: if isAuthenticated() &&
        resource.data.fromUserId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // STORIES
    // ═══════════════════════════════════════════
    match /stories/{storyId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['userId', 'mediaUrl', 'createdAt', 'expiresAt']) &&
        hasOnlyAllowedFields(['userId', 'mediaUrl', 'createdAt', 'expiresAt', 'caption', 'type', 'viewCount']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.createdAt == request.time;

      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        fieldsUnchanged(['userId', 'createdAt', 'mediaUrl']);

      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ═══════════════════════════════════════════
    // DATE SPOTS
    // ═══════════════════════════════════════════
    match /dateSpots/{spotId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['name', 'location', 'createdBy', 'createdAt']) &&
        hasOnlyAllowedFields(['name', 'location', 'createdBy', 'createdAt', 'description', 'category', 'rating', 'photos', 'address']) &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        isValidString(request.resource.data.name, 1, 100);

      allow update: if isAuthenticated() && isNotBanned() &&
        (resource.data.createdBy == request.auth.uid || isAdmin()) &&
        fieldsUnchanged(['createdBy', 'createdAt']);

      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.createdBy == request.auth.uid);
    }

    // ═══════════════════════════════════════════
    // DATE CHECKINS
    // ═══════════════════════════════════════════
    match /dateCheckins/{checkinId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['userId', 'spotId', 'createdAt']) &&
        hasOnlyAllowedFields(['userId', 'spotId', 'createdAt', 'partnerId', 'rating', 'notes']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.createdAt == request.time;

      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        fieldsUnchanged(['userId', 'spotId', 'createdAt']);

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════
    // RELATIONSHIPS
    // ═══════════════════════════════════════════
    match /relationships/{relId} {
      allow read: if isAuthenticated() &&
        (resource.data.user1 == request.auth.uid ||
         resource.data.user2 == request.auth.uid);

      allow create: if isAuthenticated() && isNotBanned() &&
        hasRequiredFields(['user1', 'user2', 'status', 'createdAt']) &&
        hasOnlyAllowedFields(['user1', 'user2', 'status', 'createdAt', 'updatedAt', 'startedAt']) &&
        (request.resource.data.user1 == request.auth.uid ||
         request.resource.data.user2 == request.auth.uid) &&
        request.resource.data.user1 != request.resource.data.user2 &&
        request.resource.data.createdAt == request.time;

      allow update: if isAuthenticated() && isNotBanned() &&
        (resource.data.user1 == request.auth.uid ||
         resource.data.user2 == request.auth.uid) &&
        fieldsUnchanged(['user1', 'user2', 'createdAt']);

      allow delete: if isAuthenticated() &&
        (resource.data.user1 == request.auth.uid ||
         resource.data.user2 == request.auth.uid);
    }

    // ═══════════════════════════════════════════
    // PERSONALITY RESULTS
    // ═══════════════════════════════════════════
    match /personalityResults/{userId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && isOwner(userId) &&
        hasRequiredFields(['personalityType', 'createdAt']) &&
        hasOnlyAllowedFields(['personalityType', 'createdAt', 'scores', 'answers']) &&
        request.resource.data.createdAt == request.time;

      allow update: if isAuthenticated() && isOwner(userId) &&
        fieldsUnchanged(['createdAt']);

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // DATING STATS
    // ═══════════════════════════════════════════
    match /datingStats/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);

      allow create: if isAuthenticated() && isOwner(userId) &&
        hasRequiredFields(['createdAt']) &&
        request.resource.data.createdAt == request.time;

      allow update: if isAuthenticated() && isOwner(userId) &&
        fieldsUnchanged(['createdAt']);

      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // CATCH-ALL (deny everything else)
    // ═══════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}