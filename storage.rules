rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.admin == true ||
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isConversationParticipant(conversationId) {
      let conversation = firestore.get(
        /databases/(default)/documents/conversations/$(conversationId)
      );
      let participantIds = conversation.data.participantIds;
      return participantIds is map && participantIds[request.auth.uid] == true;
    }

    function isValidFileId(fileId) {
      return fileId.matches('^[a-zA-Z0-9_.-]+$');
    }

    function isValidProfileImageType(contentType) {
      return contentType.matches('image/(jpeg|png|webp)');
    }

    function isValidMediaType(contentType) {
      return contentType.matches('image/.*|video/.*|audio/.*');
    }

    function isUnderSizeLimit(size, limit) {
      return size < limit;
    }

    function isValidProfileSize(size) {
      return isUnderSizeLimit(size, 10 * 1024 * 1024);
    }

    function isValidMediaSize(size) {
      return isUnderSizeLimit(size, 50 * 1024 * 1024);
    }

    function isValidVerificationSize(size) {
      return size > 1024 && isUnderSizeLimit(size, 5 * 1024 * 1024);
    }

    match /profiles/{userId}/{photoId} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && isValidFileId(photoId)
        && isValidProfileSize(request.resource.size)
        && isValidProfileImageType(request.resource.contentType);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId)
        && isValidMediaSize(request.resource.size)
        && isValidMediaType(request.resource.contentType);
    }

    match /chat_media/{conversationId}/{mediaId} {
      allow read: if isAuthenticated() && isConversationParticipant(conversationId);
      allow create, update: if isAuthenticated()
        && isConversationParticipant(conversationId)
        && isValidFileId(mediaId)
        && request.resource.metadata.customMetadata.conversationId == conversationId
        && isValidMediaSize(request.resource.size)
        && isValidMediaType(request.resource.contentType);
    }

    match /verification/{userId}/{docId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create, update: if isOwner(userId)
        && isValidFileId(docId)
        && isValidVerificationSize(request.resource.size);
      allow delete: if false;
    }

    match /evidence/{caseId}/{fileId} {
      allow read, write: if isAdmin();
    }

    match /public/images/{fileId} {
      allow read: if true;
      allow write: if false;
    }

    match /public/fonts/{fileId} {
      allow read: if true;
      allow write: if false;
    }

    match /public/assets/{fileId} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}